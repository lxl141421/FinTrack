{
  "env": {
    "es2021": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "rules": {
    "no-restricted-syntax": [
      "error",
      {
        "selector": "ForOfStatement",
        "message": "ArkTS does not support for...of, use for(let i=0; i<arr.length; i++) or forEach"
      }
    ],
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-var": "error",
    "prefer-const": "warn",
    "eqeqeq": ["error", "always"],
    "no-throw-literal": "error",
    "camelcase": ["warn", { "properties": "never" }],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error"
  },
  "overrides": [
    {
      "files": ["*.test.ets", "*.test.ts"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
